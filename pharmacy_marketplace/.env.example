# =============================================================================
# Environment variables — copy to .env and fill in
# =============================================================================
# Django
DJANGO_SECRET_KEY=insecure-dev-key-change-in-production
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,.localhost
# DJANGO_SETTINGS_MODULE=pharmacy_marketplace.settings.dev  # Uncomment for non-Docker local dev

# Database (PostgreSQL + PostGIS)
DB_NAME=pharmacy_marketplace
DB_USER=pharmacy_user
DB_PASSWORD=pharmacy_pass
DB_HOST=localhost
DB_PORT=5432
DB_CONN_MAX_AGE=60

# CORS
CORS_ALLOWED_ORIGINS=http://localhost:8000,http://127.0.0.1:8000,http://localhost:3000
CSRF_TRUSTED_ORIGINS=http://localhost:8000,http://127.0.0.1:8000

# MinIO (S3-compatible storage for dev)
AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=minioadmin
AWS_STORAGE_BUCKET_NAME=pharmacy-media
AWS_S3_ENDPOINT_URL=http://localhost:9000

# Redis
REDIS_URL=redis://localhost:6379/0
